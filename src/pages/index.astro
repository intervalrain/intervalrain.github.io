---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <!-- Hero -->
    <section id="hero" class="pb-8 pt-8 sm:pt-12">
      <div class="flex items-start gap-6">
        <img
          src="/rain.png"
          alt="Rain Hu"
          class="hidden size-20 rounded-full border-2 border-accent/20 sm:block"
        />
        <div class="flex-1">
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
            {SITE.title}
          </h1>
          <p class="mt-2 text-subtle leading-relaxed">
            To enjoy the rainbow, first enjoy the rain.
          </p>
          <p class="mt-1 text-sm text-subtle/80">
            Software Engineer / Music Creator / Lifelong Learner
          </p>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <Socials />
      </div>
    </section>

    <hr class="border-border" />

    <!-- Featured -->
    {
      featuredPosts.length > 0 && (
        <section id="featured" class="pb-6 pt-10">
          <h2 class="text-lg font-semibold uppercase tracking-widest text-subtle">
            Featured
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {featuredPosts.length > 0 && recentPosts.length > 0 && <hr class="border-border" />}

    <!-- Recent Posts -->
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pb-6 pt-10">
          <h2 class="text-lg font-semibold uppercase tracking-widest text-subtle">
            Recent Posts
          </h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
